*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#0d1117;
    color:#fff;
    line-height:1.6;
}

nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 40px;
    margin-bottom:30px;
}

nav ul{
    list-style:none;
    display:flex;
    gap:20px;
}

nav a{
    color:white;
    text-decoration:none;
    transition:.3s;
}

nav a:hover{
    color:#58a6ff;
}

.logo{
    color:#58a6ff;
}


.buttons{
    margin-top:30px;
}

.btn{
    background:#238636;
    color:white;
    padding:12px 25px;
    border-radius:8px;
    text-decoration:none;
    margin:10px;
    display:inline-block;
}

.btn:hover{
    background:#2ea043;
}

section{
    width:90%;
    max-width:1000px;
    margin:70px auto;
}

section h2{
    color:#58a6ff;
    margin-bottom:20px;
}

footer{
    text-align:center;
    padding:20px;
    background:#161b22;
    color:#999;
}
/* Skills Section */

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-top:30px;
}

.card{
    background:#161b22;
    padding:25px;
    text-align:center;
    border-radius:12px;
    border:1px solid #30363d;
    transition:0.3s;
    font-weight:bold;
}

.card:hover{
    transform:translateY(-8px);
    border-color:#58a6ff;
    box-shadow:0 10px 20px rgba(88,166,255,0.3);
}

footer{
    background:#161b22;
    text-align:center;
    padding:40px 20px;
    margin-top:60px;
    border-top:1px solid #30363d;
}

footer h3{
    color:#58a6ff;
    margin-bottom:10px;
}

footer p{
    margin:10px 0;
    color:#c9d1d9;
}

footer a{
    color:#58a6ff;
    text-decoration:none;
}

footer a:hover{
    text-decoration:underline;
}

.hero{
    min-height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:40px 20px;
    background:linear-gradient(135deg,#0d1117,#161b22);
}

.profile-photo{
    width:220px;
    height:220px;
    border-radius:50%;
    object-fit:cover;
    border:6px solid #58a6ff;
    box-shadow:0 0 30px rgba(88,166,255,.45);
    transition:.4s;
}

.profile-photo:hover{
    transform:scale(1.05);
}

.hero h1{
    font-size:3rem;
    margin-top:20px;
}

.hero h3{
    color:#58a6ff;
    margin:10px 0;
    font-size:1.5rem;
}

.hero p{
    max-width:700px;
    color:#c9d1d9;
    margin:20px auto;
    font-size:1.1rem;
}

.buttons{
    margin-top:30px;
}

.btn{
    padding:14px 30px;
    margin:10px;
    border-radius:50px;
    background:#238636;
    color:white;
    text-decoration:none;
    transition:.3s;
}

.btn:hover{
    transform:translateY(-3px);
    background:#2ea043;
}
